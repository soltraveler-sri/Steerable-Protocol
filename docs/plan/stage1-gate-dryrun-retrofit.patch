diff --git a/src/steerable/SteerableSettingsPanel.tsx b/src/steerable/SteerableSettingsPanel.tsx
new file mode 100644
index 0000000..c37d0ff
--- /dev/null
+++ b/src/steerable/SteerableSettingsPanel.tsx
@@ -0,0 +1,226 @@
+import { Activity, CheckCircle2, DatabaseBackup, FileSearch, Play, RotateCcw, Settings2, ShieldCheck, Undo2, XCircle } from 'lucide-react'
+import { useMemo } from 'react'
+import { useSteerableRuntime, type LedgerRecord } from './runtimeState'
+import type { JsonObject, JsonValue } from './schema'
+
+export function SteerableSettingsPanel() {
+  const {
+    facts,
+    records,
+    publishFacts,
+    invokeReadTool,
+    invokeAction,
+    approveRecord,
+    declineRecord,
+    undoRecord,
+    runProbe
+  } = useSteerableRuntime()
+
+  const currentTheme = factText(facts, ['preferences', 'theme'])
+  const nextTheme = currentTheme === 'dark' ? 'light' : 'dark'
+  const visibleRecords = useMemo(() => records.slice(0, 6), [records])
+
+  return (
+    <section className="classical-panel overflow-hidden rounded-md">
+      <div className="grid gap-5 px-4 py-5 sm:px-5 lg:grid-cols-[1fr_1.25fr]">
+        <div className="min-w-0">
+          <div className="flex items-start gap-3">
+            <span className="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-md border border-line bg-paper text-clay">
+              <ShieldCheck size={18} />
+            </span>
+            <div className="min-w-0">
+              <p className="text-xs uppercase tracking-[0.18em] text-graphite">Steerable pilot</p>
+              <h2 className="mt-1 font-serif text-2xl leading-tight">Settings control surface</h2>
+              <p className="mt-2 text-sm leading-6 text-graphite">
+                Bounded facts and read tools stay content-free. Preference actions run with undo; backup export waits for approval.
+              </p>
+            </div>
+          </div>
+
+          <div className="mt-4 grid gap-2 text-sm sm:grid-cols-3">
+            <FactPill label="Entries" value={factText(facts, ['library', 'totalEntries'])} />
+            <FactPill label="Backup" value={factText(facts, ['backup', 'state'])} />
+            <FactPill label="Posture" value={factText(facts, ['policy', 'posture'])} />
+          </div>
+
+          <div className="mt-4 grid gap-2 sm:grid-cols-2">
+            <ToolButton icon={<FileSearch size={15} />} label="Publish facts" onClick={publishFacts} />
+            <ToolButton icon={<Activity size={15} />} label="Run fixture probe" onClick={runProbe} />
+            <ToolButton icon={<FileSearch size={15} />} label="Read local status" onClick={() => void invokeReadTool('settings.get_local_status')} />
+            <ToolButton icon={<FileSearch size={15} />} label="Read backup status" onClick={() => void invokeReadTool('backup.get_status')} />
+            <ToolButton icon={<FileSearch size={15} />} label="Read export scope" onClick={() => void invokeReadTool('library.get_export_summary')} />
+          </div>
+
+          <div className="mt-4 grid gap-2 sm:grid-cols-2">
+            <ToolButton
+              icon={<Settings2 size={15} />}
+              label={`Set ${nextTheme} theme`}
+              onClick={() => void invokeAction('settings.set_theme', { theme: nextTheme })}
+            />
+            <ToolButton
+              icon={<RotateCcw size={15} />}
+              label="Use 5 balanced reviews"
+              onClick={() => void invokeAction('settings.set_daily_review', { dailyCount: 5, dailyMode: 'balanced' })}
+            />
+            <ToolButton
+              icon={<DatabaseBackup size={15} />}
+              label="Request JSON backup"
+              tone="primary"
+              onClick={() => void invokeAction('backup.download_json')}
+            />
+          </div>
+        </div>
+
+        <div className="min-w-0 border-t border-line pt-4 lg:border-l lg:border-t-0 lg:pl-5 lg:pt-0">
+          <div className="flex items-center justify-between gap-3">
+            <div>
+              <p className="text-xs uppercase tracking-[0.18em] text-graphite">Activity ledger</p>
+              <p className="mt-1 text-sm text-graphite">Session-only, newest first.</p>
+            </div>
+            <span className="rounded border border-line px-2 py-1 text-[11px] uppercase tracking-[0.14em] text-graphite">
+              {records.length}
+            </span>
+          </div>
+
+          <ol className="mt-3 grid gap-3">
+            {visibleRecords.length ? (
+              visibleRecords.map((record) => (
+                <LedgerItem
+                  key={record.id}
+                  record={record}
+                  onApprove={() => void approveRecord(record.id)}
+                  onDecline={() => declineRecord(record.id)}
+                  onUndo={() => void undoRecord(record.id)}
+                />
+              ))
+            ) : (
+              <li className="rounded-md border border-line bg-paper/60 px-3 py-4 text-sm text-graphite">
+                No steering activity in this session yet.
+              </li>
+            )}
+          </ol>
+        </div>
+      </div>
+    </section>
+  )
+}
+
+function FactPill({ label, value }: { label: string; value: string }) {
+  return (
+    <div className="min-w-0 border-t border-line pt-2">
+      <p className="text-[0.66rem] uppercase tracking-[0.15em] text-graphite">{label}</p>
+      <p className="mt-1 truncate text-sm text-ink">{value || 'n/a'}</p>
+    </div>
+  )
+}
+
+function ToolButton({
+  icon,
+  label,
+  tone = 'secondary',
+  onClick
+}: {
+  icon: React.ReactNode
+  label: string
+  tone?: 'primary' | 'secondary'
+  onClick: () => void
+}) {
+  return (
+    <button
+      type="button"
+      className={[
+        'inline-flex min-h-[44px] items-center justify-between gap-3 rounded-md px-3 py-2 text-left text-sm transition',
+        tone === 'primary'
+          ? 'border border-ink bg-ink text-paper hover:bg-[#171615]'
+          : 'border border-line bg-paper/70 text-graphite hover:border-ink/45 hover:text-ink'
+      ].join(' ')}
+      onClick={onClick}
+    >
+      <span className="flex min-w-0 items-center gap-2">
+        <span className="shrink-0">{icon}</span>
+        <span className="truncate">{label}</span>
+      </span>
+      <Play size={13} className="shrink-0 opacity-70" />
+    </button>
+  )
+}
+
+function LedgerItem({
+  record,
+  onApprove,
+  onDecline,
+  onUndo
+}: {
+  record: LedgerRecord
+  onApprove: () => void
+  onDecline: () => void
+  onUndo: () => void
+}) {
+  return (
+    <li className="rounded-md border border-line bg-paper/60 p-3">
+      <div className="flex items-start justify-between gap-3">
+        <div className="min-w-0">
+          <p className="truncate text-sm font-medium text-ink">{record.title}</p>
+          <p className="mt-1 text-xs text-graphite">
+            {record.mode} · {record.status.replace('_', ' ')}
+          </p>
+        </div>
+        <span className={statusClass(record.status)}>
+          {record.status === 'succeeded' || record.status === 'undone' ? <CheckCircle2 size={14} /> : <XCircle size={14} />}
+        </span>
+      </div>
+
+      <p className="mt-2 text-sm leading-6 text-graphite">{record.result?.summary ?? record.error ?? record.policyReasons[0]}</p>
+
+      {record.status === 'pending_approval' && (
+        <div className="mt-3 grid gap-2 sm:flex">
+          <button className="rounded-md bg-ink px-3 py-2 text-sm text-paper" type="button" onClick={onApprove}>
+            Approve
+          </button>
+          <button className="rounded-md border border-line px-3 py-2 text-sm text-graphite" type="button" onClick={onDecline}>
+            Decline
+          </button>
+        </div>
+      )}
+
+      {record.undo?.available && record.status === 'succeeded' && (
+        <button
+          className="mt-3 inline-flex items-center gap-2 rounded-md border border-line px-3 py-2 text-sm text-graphite"
+          type="button"
+          onClick={onUndo}
+        >
+          <Undo2 size={14} />
+          Undo
+        </button>
+      )}
+
+      {record.undo && !record.undo.available && record.status !== 'pending_approval' && (
+        <p className="mt-2 text-xs leading-5 text-graphite">{record.undo.reason}</p>
+      )}
+    </li>
+  )
+}
+
+function statusClass(status: LedgerRecord['status']) {
+  const tone =
+    status === 'succeeded' || status === 'undone'
+      ? 'border-moss text-moss'
+      : status === 'failed' || status === 'declined'
+        ? 'border-clay text-clay'
+        : 'border-line text-graphite'
+
+  return `mt-0.5 inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md border ${tone}`
+}
+
+function factText(facts: JsonObject | null, path: readonly string[]) {
+  let value: JsonValue | undefined = facts ?? undefined
+  for (const key of path) {
+    if (!isPlainJsonObject(value)) return ''
+    value = value[key]
+  }
+  return typeof value === 'string' || typeof value === 'number' || typeof value === 'boolean' ? String(value) : ''
+}
+
+function isPlainJsonObject(value: JsonValue | undefined): value is JsonObject {
+  return Boolean(value) && typeof value === 'object' && !Array.isArray(value)
+}
diff --git a/src/steerable/capabilities.ts b/src/steerable/capabilities.ts
new file mode 100644
index 0000000..650a420
--- /dev/null
+++ b/src/steerable/capabilities.ts
@@ -0,0 +1,429 @@
+import { backupState as classifyBackupState } from '../services/backup'
+import { quoteStatus } from '../types/quote'
+import type {
+  ActionDeclaration,
+  FactsDeclaration,
+  JsonObject,
+  ParamSchema,
+  ReadToolDeclaration,
+  RuntimeContext,
+  SteerableRegistry,
+  SurfaceDeclaration
+} from './schema'
+
+const allowedDailyCounts = [3, 5, 10, 15]
+
+export const quietSignalSteerableTarget = {
+  integrationId: 'quiet-signal.settings',
+  registryId: 'quiet-signal.steerable',
+  registryVersion: '0.1.0',
+  registryRef: 'src/steerable/capabilities.ts'
+} as const
+
+const emptyParams: ParamSchema = {
+  description: 'No parameters.',
+  example: {},
+  parse(input) {
+    if (input === undefined || input === null) return { ok: true, value: {} }
+    const object = parsePlainObject(input)
+    if (!object.ok) return object
+    const keys = Object.keys(object.value)
+    return keys.length === 0 ? object : { ok: false, error: `Unexpected parameter: ${keys[0]}` }
+  }
+}
+
+const themeParams: ParamSchema = {
+  description: 'Theme preference to apply.',
+  example: { theme: 'dark' },
+  parse(input) {
+    const object = parsePlainObject(input)
+    if (!object.ok) return object
+    const unknown = unknownKey(object.value, ['theme'])
+    if (unknown) return { ok: false, error: `Unexpected parameter: ${unknown}` }
+    return object.value.theme === 'light' || object.value.theme === 'dark'
+      ? { ok: true, value: { theme: object.value.theme } }
+      : { ok: false, error: 'theme must be light or dark' }
+  }
+}
+
+const dailyReviewParams: ParamSchema = {
+  description: 'Daily review count and selection mode.',
+  example: { dailyCount: 5, dailyMode: 'balanced' },
+  parse(input) {
+    const object = parsePlainObject(input)
+    if (!object.ok) return object
+    const unknown = unknownKey(object.value, ['dailyCount', 'dailyMode'])
+    if (unknown) return { ok: false, error: `Unexpected parameter: ${unknown}` }
+    const { dailyCount, dailyMode } = object.value
+    if (typeof dailyCount !== 'number' || !allowedDailyCounts.includes(dailyCount)) {
+      return { ok: false, error: 'dailyCount must be 3, 5, 10, or 15' }
+    }
+    if (dailyMode !== 'balanced' && dailyMode !== 'random') {
+      return { ok: false, error: 'dailyMode must be balanced or random' }
+    }
+    return { ok: true, value: { dailyCount, dailyMode } }
+  }
+}
+
+export const settingsFactsDeclaration: FactsDeclaration = {
+  kind: 'facts',
+  id: 'settings.current_facts',
+  surface: 'settings',
+  title: 'Settings status facts',
+  description: 'Bounded settings-surface facts with counts and status only. Raw quote and book text is never included.',
+  facts: ['route', 'library', 'backup', 'security', 'preferences', 'storage', 'policy'],
+  maxTopLevelFacts: 8,
+  rawContentIncluded: false,
+  publish(context) {
+    const counts = libraryCounts(context)
+
+    return {
+      route: {
+        path: context.route,
+        surface: 'settings',
+        live: context.activeSurfaceId === 'settings'
+      },
+      library: {
+        signalCount: counts.signalCount,
+        inboxCount: counts.inboxCount,
+        quoteCount: counts.quoteCount,
+        bookCount: counts.bookCount,
+        totalEntries: counts.totalEntries,
+        rawContentIncluded: false
+      },
+      backup: {
+        state: context.backup.backupState,
+        lastBackupAt: context.backup.lastBackupAt ?? null,
+        ageDays: context.backup.backupAgeDays ?? null
+      },
+      security: {
+        protection: protectionLevel(context),
+        pinEnabled: context.security.pinEnabled,
+        encryptionEnabled: context.security.encryptionEnabled,
+        encryptionUnlocked: context.security.encryptionUnlocked
+      },
+      preferences: {
+        theme: context.settings.theme,
+        dailyReview: {
+          count: context.settings.dailyCount,
+          mode: context.settings.dailyMode
+        },
+        reminders: {
+          enabled: context.settings.reminderEnabled,
+          time: context.settings.reminderTime
+        }
+      },
+      storage: {
+        model: 'local-first',
+        backend: 'none',
+        primaryStore: 'IndexedDB',
+        preferencesStore: 'localStorage'
+      },
+      policy: {
+        posture: 'sensitive-domain',
+        safeReversiblePreferenceActions: 'ungated',
+        sensitiveExternalActions: 'step-gated'
+      }
+    }
+  }
+}
+
+export const readToolDeclarations: readonly ReadToolDeclaration[] = [
+  {
+    kind: 'read_tool',
+    id: 'settings.get_local_status',
+    surface: 'settings',
+    title: 'Get local settings status',
+    description: 'Returns local counts, protection status, and preference settings without raw quote text.',
+    params: emptyParams,
+    reads: ['settings.current_facts'],
+    externalExposure: 'none',
+    rawContentIncluded: false,
+    read(context) {
+      const facts = settingsFactsDeclaration.publish(context)
+      return {
+        summary: 'Local settings status returned without raw quote or book text.',
+        data: facts
+      }
+    }
+  },
+  {
+    kind: 'read_tool',
+    id: 'backup.get_status',
+    surface: 'settings',
+    title: 'Get backup status',
+    description: 'Returns backup freshness and entry counts without generating a file.',
+    params: emptyParams,
+    reads: ['backup.last_backup_at', 'library.counts'],
+    externalExposure: 'none',
+    rawContentIncluded: false,
+    read(context) {
+      const counts = libraryCounts(context)
+      return {
+        summary: `${context.backup.backupState} backup status for ${counts.totalEntries} local entries.`,
+        data: {
+          state: context.backup.backupState,
+          lastBackupAt: context.backup.lastBackupAt ?? null,
+          ageDays: context.backup.backupAgeDays ?? null,
+          totalEntries: counts.totalEntries,
+          rawContentIncluded: false
+        }
+      }
+    }
+  },
+  {
+    kind: 'read_tool',
+    id: 'library.get_export_summary',
+    surface: 'settings',
+    title: 'Get export summary',
+    description: 'Summarizes exportable counts and sensitivity without exposing quote or book contents.',
+    params: emptyParams,
+    reads: ['library.counts', 'backup.supported_formats'],
+    externalExposure: 'none',
+    rawContentIncluded: false,
+    read(context) {
+      const counts = libraryCounts(context)
+      return {
+        summary: 'Export scope summarized without raw content.',
+        data: {
+          formats: ['json', 'csv', 'markdown'],
+          quoteCount: counts.quoteCount,
+          bookCount: counts.bookCount,
+          totalEntries: counts.totalEntries,
+          includesSensitiveContent: counts.totalEntries > 0,
+          rawContentIncluded: false
+        }
+      }
+    }
+  }
+]
+
+export const actionDeclarations: readonly ActionDeclaration[] = [
+  {
