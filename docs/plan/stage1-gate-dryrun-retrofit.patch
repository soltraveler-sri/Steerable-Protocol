+import { useCallback, useMemo, useState, type ReactNode } from 'react'
+import { useLocation } from 'react-router-dom'
+import { backupAgeDays, backupState, downloadBackup, getLastBackupAt } from '../services/backup'
+import { hasPinLock, isEncryptionEnabled, isEncryptionUnlocked } from '../services/security'
+import { useBookStore } from '../store/useBookStore'
+import { useQuoteStore } from '../store/useQuoteStore'
+import { useSettingsStore } from '../store/useSettingsStore'
+import {
+  getActionDeclaration,
+  getReadToolDeclaration,
+  quietSignalRegistry,
+  settingsFactsDeclaration
+} from './capabilities'
+import { runSteerableFixtureProbe } from './fixtures'
+import { readOnlyPolicyDecision, resolveActionPolicy, type PolicyDecision } from './policy'
+import { SteerableRuntimeContext, type LedgerRecord, type LedgerUndoState, type SteerableRuntimeValue } from './runtimeState'
+import type { ActionDeclaration, JsonObject, RuntimeContext, SurfaceId } from './schema'
+
+export function SteerableProvider({ children }: { children: ReactNode }) {
+  const location = useLocation()
+  const quotes = useQuoteStore((state) => state.quotes)
+  const books = useBookStore((state) => state.books)
+  const settings = useSettingsStore()
+  const [records, setRecords] = useState<LedgerRecord[]>([])
+
+  const activeSurfaceId: SurfaceId | null = location.pathname === '/settings' ? 'settings' : null
+  const lastBackupAt = getLastBackupAt()
+  const currentBackupAge = backupAgeDays(lastBackupAt)
+  const currentBackupState = backupState(quotes.length + books.length, lastBackupAt)
+
+  const runtimeContext: RuntimeContext = useMemo(
+    () => ({
+      route: location.pathname,
+      activeSurfaceId,
+      quotes,
+      books,
+      settings: {
+        theme: settings.theme,
+        dailyCount: settings.dailyCount,
+        dailyMode: settings.dailyMode,
+        reminderEnabled: settings.reminderEnabled,
+        reminderTime: settings.reminderTime,
+        setTheme: settings.setTheme,
+        setDailyCount: settings.setDailyCount,
+        setDailyMode: settings.setDailyMode
+      },
+      security: {
+        pinEnabled: hasPinLock(),
+        encryptionEnabled: isEncryptionEnabled(),
+        encryptionUnlocked: isEncryptionUnlocked()
+      },
+      backup: {
+        lastBackupAt,
+        backupAgeDays: currentBackupAge,
+        backupState: currentBackupState,
+        downloadBackup
+      },
+      now: () => new Date()
+    }),
+    [
+      activeSurfaceId,
+      books,
+      currentBackupAge,
+      currentBackupState,
+      lastBackupAt,
+      location.pathname,
+      quotes,
+      settings.dailyCount,
+      settings.dailyMode,
+      settings.reminderEnabled,
+      settings.reminderTime,
+      settings.setDailyCount,
+      settings.setDailyMode,
+      settings.setTheme,
+      settings.theme
+    ]
+  )
+
+  const facts = useMemo(() => (activeSurfaceId === 'settings' ? settingsFactsDeclaration.publish(runtimeContext) : null), [activeSurfaceId, runtimeContext])
+
+  const appendRecord = useCallback((record: LedgerRecord) => {
+    setRecords((current) => [record, ...current].slice(0, 20))
+  }, [])
+
+  const patchRecord = useCallback((recordId: string, patch: Partial<LedgerRecord>) => {
+    setRecords((current) => current.map((record) => (record.id === recordId ? { ...record, ...patch } : record)))
+  }, [])
+
+  const publishFacts = useCallback(() => {
+    const policy = readOnlyPolicyDecision()
+    if (activeSurfaceId !== 'settings') {
+      appendRecord(
+        baseRecord({
+          kind: 'facts',
+          surfaceId: activeSurfaceId,
+          capabilityId: 'settings.current_facts',
+          title: settingsFactsDeclaration.title,
+          status: 'failed',
+          mode: policy.mode,
+          policyReasons: policy.reasons,
+          params: {},
+          error: 'Settings surface is not active.'
+        })
+      )
+      return
+    }
+
+    appendRecord(
+      baseRecord({
+        kind: 'facts',
+        surfaceId: activeSurfaceId,
+        capabilityId: 'settings.current_facts',
+        title: settingsFactsDeclaration.title,
+        status: 'succeeded',
+        mode: policy.mode,
+        policyReasons: policy.reasons,
+        params: {},
+        result: {
+          summary: 'Settings facts published without raw content.',
+          data: settingsFactsDeclaration.publish(runtimeContext)
+        }
+      })
+    )
+  }, [activeSurfaceId, appendRecord, runtimeContext])
+
+  const invokeReadTool = useCallback(
+    async (id: Parameters<typeof getReadToolDeclaration>[0], params: JsonObject = {}) => {
+      const tool = getReadToolDeclaration(id)
+      const policy = readOnlyPolicyDecision()
+
+      if (!tool) {
+        appendRecord(
+          baseRecord({
+            kind: 'read_tool',
+            surfaceId: activeSurfaceId,
+            capabilityId: id,
+            title: id,
+            status: 'failed',
+            mode: policy.mode,
+            policyReasons: policy.reasons,
+            params,
+            error: 'Unknown read tool.'
+          })
+        )
+        return
+      }
+
+      const parsed = tool.params.parse(params)
+      if (!parsed.ok) {
+        appendRecord(
+          baseRecord({
+            kind: 'read_tool',
+            surfaceId: activeSurfaceId,
+            capabilityId: tool.id,
+            title: tool.title,
+            status: 'failed',
+            mode: policy.mode,
+            policyReasons: policy.reasons,
+            params,
+            error: parsed.error
+          })
+        )
+        return
+      }
+
+      if (activeSurfaceId !== tool.surface) {
+        appendRecord(
+          baseRecord({
+            kind: 'read_tool',
+            surfaceId: activeSurfaceId,
+            capabilityId: tool.id,
+            title: tool.title,
+            status: 'failed',
+            mode: policy.mode,
+            policyReasons: policy.reasons,
+            params: parsed.value,
+            error: 'Read tool surface is not active.'
+          })
+        )
+        return
+      }
+
+      try {
+        appendRecord(
+          baseRecord({
+            kind: 'read_tool',
+            surfaceId: activeSurfaceId,
+            capabilityId: tool.id,
+            title: tool.title,
+            status: 'succeeded',
+            mode: policy.mode,
+            policyReasons: policy.reasons,
+            params: parsed.value,
+            result: tool.read(runtimeContext, parsed.value)
+          })
+        )
+      } catch (error) {
+        appendRecord(
+          baseRecord({
+            kind: 'read_tool',
+            surfaceId: activeSurfaceId,
+            capabilityId: tool.id,
+            title: tool.title,
+            status: 'failed',
+            mode: policy.mode,
+            policyReasons: policy.reasons,
+            params: parsed.value,
+            error: errorMessage(error)
+          })
+        )
+      }
+    },
+    [activeSurfaceId, appendRecord, runtimeContext]
+  )
+
+  const executeActionRecord = useCallback(
+    async (recordId: string, action: ActionDeclaration, params: JsonObject, decision: PolicyDecision, approval: 'approved' | undefined) => {
+      const undoPayload = action.captureUndo?.(runtimeContext, params)
+
+      try {
+        const result = await action.execute(runtimeContext, params)
+        patchRecord(recordId, {
+          status: 'succeeded',
+          approval,
+          result,
+          undoPayload,
+          undo: undoStateFor(action, undoPayload)
+        })
+      } catch (error) {
+        patchRecord(recordId, {
+          status: 'failed',
+          approval,
+          error: errorMessage(error),
+          undo: {
+            available: false,
+            status: 'failed',
+            reason: 'Action failed before an undo state was available.'
+          }
+        })
+      }
+
+      void decision
+    },
+    [patchRecord, runtimeContext]
+  )
+
+  const appendPolicyRecord = useCallback(
+    (action: ActionDeclaration, params: JsonObject, decision: PolicyDecision) => {
+      const recordId = ledgerId()
+      appendRecord(
+        baseRecord({
+          id: recordId,
+          kind: 'policy',
+          surfaceId: activeSurfaceId,
+          capabilityId: action.id,
+          title: `Policy for ${action.title}`,
+          status: 'succeeded',
+          mode: decision.mode,
+          policyReasons: decision.reasons,
+          params,
+          result: {
+            summary: `Resolved ${action.id} to ${decision.mode}.`,
+            data: {
+              actionId: action.id,
+              posture: decision.posture,
+              mode: decision.mode,
+              reasonCodes: decision.reasons,
+              risk: action.risk,
+              reversibility: action.reversibility,
+              effects: {
+                external: action.effects.external,
+                cost: action.effects.cost,
+                sensitive: action.effects.sensitive
+              },
+              confirmation: action.confirmation
+            }
+          }
+        })
+      )
+      return recordId
+    },
+    [activeSurfaceId, appendRecord]
+  )
+
+  const invokeAction = useCallback(
+    async (id: Parameters<typeof getActionDeclaration>[0], params: JsonObject = {}) => {
+      const action = getActionDeclaration(id)
+
+      if (!action) {
+        appendRecord(
+          baseRecord({
+            kind: 'action',
+            surfaceId: activeSurfaceId,
+            capabilityId: id,
+            title: id,
+            status: 'failed',
+            mode: 'Step-gated',
+            policyReasons: ['unknown_action'],
+            params,
+            error: 'Unknown action.'
+          })
+        )
+        return
+      }
+
+      const parsed = action.params.parse(params)
+      if (!parsed.ok) {
+        const decision = resolveActionPolicy(action)
+        appendRecord(
+          baseRecord({
+            kind: 'action',
+            surfaceId: activeSurfaceId,
+            capabilityId: action.id,
+            title: action.title,
+            status: 'failed',
+            mode: decision.mode,
+            policyReasons: decision.reasons,
+            params,
+            error: parsed.error
+          })
+        )
+        return
+      }
+
+      const surfaceError = activeSurfaceId !== action.surface ? 'Action surface is not active.' : null
+      const precondition = surfaceError ? { ok: false as const, reason: surfaceError } : action.preconditions(runtimeContext, parsed.value)
+      if (!precondition.ok) {
+        const decision = resolveActionPolicy(action)
+        appendRecord(
+          baseRecord({
+            kind: 'action',
+            surfaceId: activeSurfaceId,
+            capabilityId: action.id,
+            title: action.title,
+            status: 'failed',
+            mode: decision.mode,
+            policyReasons: decision.reasons,
+            params: parsed.value,
+            error: precondition.reason
+          })
+        )
+        return
+      }
+
+      const decision = resolveActionPolicy(action)
+      const policyRecordId = appendPolicyRecord(action, parsed.value, decision)
+      const record = baseRecord({
+        kind: 'action',
+        surfaceId: activeSurfaceId,
+        capabilityId: action.id,
+        relatedRecordId: policyRecordId,
+        title: action.title,
+        status: decision.requiresApproval ? 'pending_approval' : 'running',
+        mode: decision.mode,
+        policyReasons: decision.reasons,
+        params: parsed.value,
+        parsedParams: parsed.value,
+        approval: decision.requiresApproval ? 'pending' : undefined,
+        undo: decision.requiresApproval
+          ? {
+              available: false,
+              status: action.undo ? 'available' : 'not_supported',
+              reason: decision.requiresApproval ? 'Undo state is captured only if the approved action executes.' : ''
+            }
+          : undefined
+      })
+
+      appendRecord(record)
+      if (!decision.requiresApproval) {
+        await executeActionRecord(record.id, action, parsed.value, decision, undefined)
+      }
+    },
+    [activeSurfaceId, appendPolicyRecord, appendRecord, executeActionRecord, runtimeContext]
+  )
+
+  const approveRecord = useCallback(
+    async (recordId: string) => {
+      const record = records.find((candidate) => candidate.id === recordId)
+      const action = record?.kind === 'action' ? quietSignalRegistry.actions.find((candidate) => candidate.id === record.capabilityId) : undefined
+      if (!record || !action || record.status !== 'pending_approval' || !record.parsedParams) return
+
+      const decision = resolveActionPolicy(action)
+      const precondition = action.preconditions(runtimeContext, record.parsedParams)
+      if (!precondition.ok) {
+        patchRecord(record.id, {
+          status: 'failed',
+          approval: 'approved',
+          error: precondition.reason
+        })
+        return
+      }
+
+      appendRecord(
+        baseRecord({
+          kind: 'approval',
+          surfaceId: activeSurfaceId,
+          capabilityId: action.id,
+          relatedRecordId: record.id,
+          title: `Approve ${action.title}`,
+          status: 'succeeded',
+          mode: decision.mode,
+          policyReasons: decision.reasons,
+          params: record.parsedParams,
+          result: {
+            summary: 'User approved gated action execution.',
+            data: {
+              actionId: action.id,
+              approved: true
+            }
+          }
+        })
+      )
+      patchRecord(record.id, { status: 'running', approval: 'approved' })
+      await executeActionRecord(record.id, action, record.parsedParams, decision, 'approved')
+    },
+    [activeSurfaceId, appendRecord, executeActionRecord, patchRecord, records, runtimeContext]
+  )
+
+  const declineRecord = useCallback(
+    (recordId: string) => {
+      const record = records.find((candidate) => candidate.id === recordId)
+      if (record?.kind === 'action') {
+        appendRecord(
+          baseRecord({
+            kind: 'approval',
+            surfaceId: activeSurfaceId,
+            capabilityId: record.capabilityId,
+            relatedRecordId: record.id,
+            title: `Decline ${record.title}`,
+            status: 'declined',
+            mode: record.mode,
+            policyReasons: record.policyReasons,
+            params: record.parsedParams ?? record.params,
+            result: {
+              summary: 'User declined gated action execution.',
+              data: {
+                actionId: record.capabilityId,
+                approved: false
+              }
+            }
+          })
+        )
+      }
+      patchRecord(recordId, {
+        status: 'declined',
+        approval: 'declined',
+        result: {
+          summary: 'Action was declined before execution.'
+        },
+        undo: {
+          available: false,
+          status: 'not_supported',
+          reason: 'No execution occurred, so there is nothing to undo.'
+        }
+      })
+    },
+    [activeSurfaceId, appendRecord, patchRecord, records]
+  )
+
+  const undoRecord = useCallback(
+    async (recordId: string) => {
+      const record = records.find((candidate) => candidate.id === recordId)
+      const action = record?.kind === 'action' ? quietSignalRegistry.actions.find((candidate) => candidate.id === record.capabilityId) : undefined
+      if (!record || !action || !action.undo || !record.undoPayload) return
+
+      const undoRecordId = ledgerId()
+      const undoAttempt = baseRecord({
+        id: undoRecordId,
+        kind: 'undo',
+        surfaceId: activeSurfaceId,
+        capabilityId: action.id,
+        title: `Undo ${action.title}`,
+        status: 'running',
+        mode: record.mode,
+        policyReasons: ['undo_declared_handler'],
+        params: record.undoPayload
+      })
+      appendRecord(undoAttempt)
+
+      try {
+        const result = await action.undo(runtimeContext, record.undoPayload)
+        patchRecord(undoRecordId, {
+          status: 'succeeded',
+          result
+        })
+        patchRecord(record.id, {
+          status: 'undone',
+          undo: {
+            available: false,
+            status: 'completed',
+            reason: 'Undo completed through the action-owned handler.'
+          }
+        })
+      } catch (error) {
+        patchRecord(undoRecordId, {
+          status: 'failed',
+          error: errorMessage(error)
+        })
+        patchRecord(record.id, {
+          undo: {
+            available: true,
+            status: 'failed',
+            reason: errorMessage(error)
+          }
+        })
+      }
+    },
+    [activeSurfaceId, appendRecord, patchRecord, records, runtimeContext]
+  )
+
+  const runProbe = useCallback(() => {
+    const result = runSteerableFixtureProbe()
+    appendRecord(
+      baseRecord({
+        kind: 'probe',
+        surfaceId: activeSurfaceId,
+        capabilityId: 'steerable.fixture_probe',
+        title: 'Run fixture probe',
+        status: result.ok ? 'succeeded' : 'failed',
+        mode: 'Read-only',
+        policyReasons: ['local_fixture_probe_read_only'],
+        params: {},
+        result: {
+          summary: result.summary,
+          data: {
+            checked: result.checked,
+            failures: result.failures,
+            coverageCells: result.coverageCells
+          }
+        }
+      })
+    )
+  }, [activeSurfaceId, appendRecord])
+
+  const value = useMemo<SteerableRuntimeValue>(
+    () => ({
+      registry: quietSignalRegistry,
+      activeSurfaceId,
+      facts,
+      records,
+      publishFacts,
+      invokeReadTool,
+      invokeAction,
+      approveRecord,
+      declineRecord,
+      undoRecord,
+      runProbe
+    }),
+    [activeSurfaceId, approveRecord, declineRecord, facts, invokeAction, invokeReadTool, publishFacts, records, runProbe, undoRecord]
+  )
+
+  return <SteerableRuntimeContext.Provider value={value}>{children}</SteerableRuntimeContext.Provider>
+}
+
+function baseRecord(record: Omit<LedgerRecord, 'id' | 'schemaVersion' | 'at' | 'initiator'> & { id?: string; at?: string }): LedgerRecord {
+  return {
+    ...record,
+    id: record.id ?? ledgerId(),
+    schemaVersion: 'quiet-signal-steerable-ledger.v1',
+    initiator: 'steerable_panel',
+    at: record.at ?? new Date().toISOString()
+  }
+}
+
+function ledgerId() {
+  return crypto.randomUUID?.() ?? `ledger-${Date.now()}-${Math.random().toString(16).slice(2)}`
+}
+
+function undoStateFor(action: ActionDeclaration, undoPayload?: JsonObject): LedgerUndoState {
+  if (action.undo && undoPayload) {
+    return {
+      available: true,
+      status: 'available',
+      reason: 'Undo payload captured before execution.'
+    }
+  }
+
+  if (action.reversibility === 'irreversible') {
+    return {
+      available: false,
+      status: 'not_supported',
+      reason: 'The declaration is irreversible; no app-owned undo exists after execution.'
+    }
+  }
+
+  return {
+    available: false,
+    status: 'not_supported',
+    reason: 'No undo handler was declared for this action.'
+  }
+}
+
+function errorMessage(error: unknown) {
+  return error instanceof Error ? error.message : String(error)
+}
