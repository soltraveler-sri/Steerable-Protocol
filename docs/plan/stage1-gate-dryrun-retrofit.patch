+    guidance: 'This leaves app-controlled storage and includes user content; require an explicit approval step.',
+    examples: [{ label: 'Download a JSON backup', params: {} }],
+    preconditions(context) {
+      if (context.security.encryptionEnabled && !context.security.encryptionUnlocked) {
+        return { ok: false, reason: 'Vault is locked; unlock before exporting a backup.' }
+      }
+      return { ok: true }
+    },
+    execute(context) {
+      const timestamp = context.backup.downloadBackup(context.quotes, context.books)
+      return {
