+import type { ActionDeclaration, PolicyMode, PolicyPosture } from './schema'
+
+export interface PolicyDecision {
+  posture: PolicyPosture
+  mode: PolicyMode
+  requiresApproval: boolean
+  reasons: string[]
+}
+
+export const quietSignalPolicyPosture: PolicyPosture = 'sensitive-domain'
+
+export const policyTemplateContrast = {
+  stableDeclarations: ['settings.set_theme', 'settings.set_daily_review', 'backup.download_json'],
+  sensitiveDomainOutcomes: {
+    'settings.set_theme': 'Optimistic chain',
+    'settings.set_daily_review': 'Optimistic chain',
+    'backup.download_json': 'Step-gated'
+  }
+} as const
+
+export function resolveActionPolicy(action: ActionDeclaration): PolicyDecision {
+  if (action.confirmation === 'always') {
+    return stepGated(['confirmation_always'])
+  }
+
+  if (isCleanSafeReversible(action)) {
+    return {
+      posture: quietSignalPolicyPosture,
+      mode: 'Optimistic chain',
+      requiresApproval: false,
+      reasons: ['safe_reversible_preference']
+    }
+  }
+
+  if (action.effects.sensitive && (action.effects.external || action.reversibility === 'irreversible')) {
+    return stepGated(['sensitive_external_irreversible'])
+  }
+
+  if (action.risk === 'side_effect' || action.effects.external || action.reversibility === 'irreversible') {
+    return stepGated(['side_effect_external_or_irreversible'])
+  }
+
+  if (action.risk === 'destructive') {
+    return stepGated(['destructive_action'])
+  }
+
+  return {
+    posture: quietSignalPolicyPosture,
+    mode: 'Plan preview',
+    requiresApproval: true,
+    reasons: ['not_clean_safe_reversible']
+  }
+}
+
+export function readOnlyPolicyDecision(): PolicyDecision {
+  return {
+    posture: quietSignalPolicyPosture,
+    mode: 'Read-only',
+    requiresApproval: false,
+    reasons: ['read_only_bounded_context']
+  }
+}
+
+function isCleanSafeReversible(action: ActionDeclaration) {
+  return (
+    action.risk === 'safe' &&
+    (action.reversibility === 'undoable' || action.reversibility === 'snapshot') &&
+    action.effects.external === false &&
+    action.effects.cost === 'none' &&
+    action.effects.sensitive === false &&
+    action.confirmation !== 'always'
+  )
+}
+
+function stepGated(reasons: string[]): PolicyDecision {
+  return {
+    posture: quietSignalPolicyPosture,
+    mode: 'Step-gated',
+    requiresApproval: true,
+    reasons
+  }
+}
