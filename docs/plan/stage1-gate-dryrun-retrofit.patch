+import { createContext, useContext } from 'react'
+import { getActionDeclaration, getReadToolDeclaration, quietSignalRegistry } from './capabilities'
+import type { CapabilityId, ExecutionResult, JsonObject, PolicyMode, SurfaceId } from './schema'
+
+export type LedgerRecordKind = 'facts' | 'read_tool' | 'policy' | 'approval' | 'action' | 'undo' | 'probe'
+export type LedgerRecordStatus = 'running' | 'pending_approval' | 'succeeded' | 'failed' | 'declined' | 'undone'
+
+export interface LedgerUndoState {
+  available: boolean
+  status: 'available' | 'completed' | 'not_supported' | 'failed'
+  reason: string
+}
+
+export interface LedgerRecord {
+  id: string
+  schemaVersion: 'quiet-signal-steerable-ledger.v1'
+  at: string
+  kind: LedgerRecordKind
+  initiator: 'steerable_panel'
+  surfaceId: SurfaceId | null
+  capabilityId: CapabilityId | 'steerable.fixture_probe'
+  relatedRecordId?: string
+  title: string
+  status: LedgerRecordStatus
+  mode: PolicyMode
+  policyReasons: string[]
+  params: JsonObject
+  result?: ExecutionResult
+  error?: string
+  approval?: 'pending' | 'approved' | 'declined'
+  undo?: LedgerUndoState
+  undoPayload?: JsonObject
+  parsedParams?: JsonObject
+}
+
+export interface SteerableRuntimeValue {
+  registry: typeof quietSignalRegistry
+  activeSurfaceId: SurfaceId | null
+  facts: JsonObject | null
+  records: LedgerRecord[]
+  publishFacts: () => void
+  invokeReadTool: (id: Parameters<typeof getReadToolDeclaration>[0], params?: JsonObject) => Promise<void>
+  invokeAction: (id: Parameters<typeof getActionDeclaration>[0], params?: JsonObject) => Promise<void>
+  approveRecord: (recordId: string) => Promise<void>
+  declineRecord: (recordId: string) => void
+  undoRecord: (recordId: string) => Promise<void>
+  runProbe: () => void
+}
+
+export const SteerableRuntimeContext = createContext<SteerableRuntimeValue | null>(null)
+
+export function useSteerableRuntime() {
+  const value = useContext(SteerableRuntimeContext)
+  if (!value) throw new Error('useSteerableRuntime must be used inside SteerableProvider')
+  return value
+}
diff --git a/src/steerable/schema.ts b/src/steerable/schema.ts
new file mode 100644
index 0000000..1cca596
--- /dev/null
+++ b/src/steerable/schema.ts
@@ -0,0 +1,159 @@
+import type { Book } from '../types/book'
+import type { Quote } from '../types/quote'
+import type { AppTheme, DailyMode } from '../store/useSettingsStore'
+import type { BackupState } from '../services/backup'
+
+export type JsonValue = string | number | boolean | null | JsonObject | JsonValue[]
+export type JsonObject = { [key: string]: JsonValue }
+
+export type SurfaceId = 'settings'
+export type CapabilityId =
+  | 'settings.current_facts'
+  | 'settings.get_local_status'
+  | 'backup.get_status'
+  | 'library.get_export_summary'
+  | 'settings.set_theme'
+  | 'settings.set_daily_review'
+  | 'backup.download_json'
+
+export type RiskClass = 'safe' | 'side_effect' | 'destructive'
+export type Reversibility = 'undoable' | 'snapshot' | 'irreversible'
+export type ConfirmationRule = 'never' | 'policy' | 'always'
+export type PolicyPosture = 'sensitive-domain'
+export type PolicyMode = 'Read-only' | 'Instant execution' | 'Optimistic chain' | 'Plan preview' | 'Step-gated' | 'Gated suffix'
+export type ExternalExposure = 'none' | 'eligible'
+
+export interface EffectFlags {
+  external: boolean
+  cost: 'none' | 'metered'
+  sensitive: boolean
+}
+
+export interface RuntimeContext {
+  route: string
+  activeSurfaceId: SurfaceId | null
+  quotes: Quote[]
+  books: Book[]
+  settings: {
+    theme: AppTheme
+    dailyCount: number
+    dailyMode: DailyMode
+    reminderEnabled: boolean
+    reminderTime: string
+    setTheme: (theme: AppTheme) => void
+    setDailyCount: (count: number) => void
+    setDailyMode: (mode: DailyMode) => void
+  }
+  security: {
+    pinEnabled: boolean
+    encryptionEnabled: boolean
+    encryptionUnlocked: boolean
+  }
+  backup: {
+    lastBackupAt?: string
+    backupAgeDays?: number
+    backupState: BackupState
+    downloadBackup: (quotes: Quote[], books: Book[]) => string
+  }
+  now: () => Date
+}
+
+export interface ParseSuccess {
+  ok: true
+  value: JsonObject
+}
+
+export interface ParseFailure {
+  ok: false
+  error: string
+}
+
+export type ParseResult = ParseSuccess | ParseFailure
+
+export interface ParamSchema {
+  description: string
+  example: JsonObject
+  parse: (input: unknown) => ParseResult
+}
+
+export interface ExecutionResult {
+  summary: string
+  data?: JsonObject
+}
+
+export interface PreconditionSuccess {
+  ok: true
+}
+
+export interface PreconditionFailure {
+  ok: false
+  reason: string
+}
+
+export type PreconditionResult = PreconditionSuccess | PreconditionFailure
+
+export interface FactsDeclaration {
+  kind: 'facts'
+  id: 'settings.current_facts'
+  surface: SurfaceId
+  title: string
+  description: string
+  facts: readonly string[]
+  maxTopLevelFacts: number
+  rawContentIncluded: false
+  publish: (context: RuntimeContext) => JsonObject
+}
+
+export interface ReadToolDeclaration {
+  kind: 'read_tool'
+  id: Extract<CapabilityId, 'settings.get_local_status' | 'backup.get_status' | 'library.get_export_summary'>
+  surface: SurfaceId
+  title: string
+  description: string
+  params: ParamSchema
+  reads: readonly string[]
+  externalExposure: ExternalExposure
+  rawContentIncluded: false
+  read: (context: RuntimeContext, params: JsonObject) => ExecutionResult
+}
+
+export interface ActionDeclaration {
+  kind: 'action'
+  id: Extract<CapabilityId, 'settings.set_theme' | 'settings.set_daily_review' | 'backup.download_json'>
+  surface: SurfaceId
+  title: string
+  description: string
+  params: ParamSchema
+  reads: readonly string[]
+  writes: readonly string[]
+  risk: RiskClass
+  reversibility: Reversibility
+  effects: EffectFlags
+  confirmation: ConfirmationRule
+  externalExposure: ExternalExposure
+  guidance: string
+  examples: readonly { label: string; params: JsonObject }[]
+  preconditions: (context: RuntimeContext, params: JsonObject) => PreconditionResult
+  captureUndo?: (context: RuntimeContext, params: JsonObject) => JsonObject
+  execute: (context: RuntimeContext, params: JsonObject) => ExecutionResult | Promise<ExecutionResult>
+  undo?: (context: RuntimeContext, undo: JsonObject) => ExecutionResult | Promise<ExecutionResult>
+}
+
+export interface SurfaceDeclaration {
+  kind: 'surface'
+  id: SurfaceId
+  route: '/settings'
+  title: string
+  description: string
+  facts: readonly FactsDeclaration['id'][]
+  readTools: readonly ReadToolDeclaration['id'][]
+  actions: readonly ActionDeclaration['id'][]
+}
+
+export interface SteerableRegistry {
+  posture: PolicyPosture
+  surfaces: readonly SurfaceDeclaration[]
+  facts: readonly FactsDeclaration[]
+  readTools: readonly ReadToolDeclaration[]
+  actions: readonly ActionDeclaration[]
+}
