+    reads: ['settings.daily_review'],
+    writes: ['settings.daily_review', 'localStorage.quiet-signal-review-settings'],
+    risk: 'safe',
+    reversibility: 'undoable',
+    effects: { external: false, cost: 'none', sensitive: false },
+    confirmation: 'never',
+    externalExposure: 'none',
+    guidance: 'Use for reversible local preference changes; keep content selection and quote text out of parameters.',
+    examples: [
+      { label: 'Balanced daily review', params: { dailyCount: 5, dailyMode: 'balanced' } },
+      { label: 'Short random daily review', params: { dailyCount: 3, dailyMode: 'random' } }
+    ],
+    preconditions() {
+      return { ok: true }
+    },
+    captureUndo(context) {
+      return {
