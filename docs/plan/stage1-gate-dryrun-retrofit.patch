+export const surfaceDeclarations: readonly SurfaceDeclaration[] = [
+  {
+    kind: 'surface',
+    id: 'settings',
+    route: '/settings',
+    title: 'Settings',
+    description: 'Local preferences, privacy, backup, and release-readiness controls.',
+    facts: ['settings.current_facts'],
+    readTools: ['settings.get_local_status', 'backup.get_status', 'library.get_export_summary'],
+    actions: ['settings.set_theme', 'settings.set_daily_review', 'backup.download_json']
+  }
+]
+
+export const quietSignalRegistry: SteerableRegistry = createRegistry({
+  posture: 'sensitive-domain',
+  surfaces: surfaceDeclarations,
+  facts: [settingsFactsDeclaration],
+  readTools: readToolDeclarations,
+  actions: actionDeclarations
+})
+
+export function getSurfaceDeclaration(id: SurfaceDeclaration['id']) {
+  return quietSignalRegistry.surfaces.find((surface) => surface.id === id)
+}
+
+export function getReadToolDeclaration(id: ReadToolDeclaration['id']) {
+  return quietSignalRegistry.readTools.find((tool) => tool.id === id)
+}
+
+export function getActionDeclaration(id: ActionDeclaration['id']) {
+  return quietSignalRegistry.actions.find((action) => action.id === id)
+}
+
+export function libraryCounts(context: RuntimeContext) {
+  const inboxCount = context.quotes.filter((quote) => quoteStatus(quote) === 'inbox').length
+  const quoteCount = context.quotes.length
+  const bookCount = context.books.length
+
+  return {
+    inboxCount,
+    signalCount: quoteCount - inboxCount,
+    quoteCount,
+    bookCount,
+    totalEntries: quoteCount + bookCount
+  }
+}
+
+function protectionLevel(context: RuntimeContext) {
+  if (context.security.pinEnabled && context.security.encryptionEnabled) return 'pin-and-vault'
+  if (context.security.pinEnabled) return 'pin-only'
+  if (context.security.encryptionEnabled) return 'vault-only'
+  return 'open'
+}
+
+function parsePlainObject(input: unknown) {
+  if (!input || typeof input !== 'object' || Array.isArray(input)) {
+    return { ok: false as const, error: 'Parameters must be an object.' }
+  }
+  return { ok: true as const, value: input as JsonObject }
+}
+
+function unknownKey(value: JsonObject, allowed: readonly string[]) {
+  return Object.keys(value).find((key) => !allowed.includes(key))
+}
+
+function createRegistry(registry: SteerableRegistry): SteerableRegistry {
+  const ids = [
+    ...registry.surfaces.map((surface) => surface.id),
+    ...registry.facts.map((facts) => facts.id),
+    ...registry.readTools.map((tool) => tool.id),
+    ...registry.actions.map((action) => action.id)
+  ]
+  assertUnique(ids)
+
+  for (const surface of registry.surfaces) {
+    assertRefs(surface.facts, registry.facts.map((facts) => facts.id), `${surface.id}.facts`)
+    assertRefs(surface.readTools, registry.readTools.map((tool) => tool.id), `${surface.id}.readTools`)
+    assertRefs(surface.actions, registry.actions.map((action) => action.id), `${surface.id}.actions`)
+  }
+
+  return registry
+}
+
+function assertUnique(ids: readonly string[]) {
+  const seen = new Set<string>()
+  for (const id of ids) {
+    if (seen.has(id)) throw new Error(`Duplicate Steerable capability id: ${id}`)
+    seen.add(id)
+  }
+}
+
+function assertRefs(refs: readonly string[], ids: readonly string[], label: string) {
+  for (const ref of refs) {
+    if (!ids.includes(ref)) throw new Error(`Unknown Steerable reference in ${label}: ${ref}`)
+  }
+}
+
+export function expectedBackupState(context: RuntimeContext) {
+  return classifyBackupState(context.quotes.length + context.books.length, context.backup.lastBackupAt)
+}
