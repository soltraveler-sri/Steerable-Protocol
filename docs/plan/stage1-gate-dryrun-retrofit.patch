+import {
+  actionDeclarations,
+  quietSignalSteerableTarget,
+  quietSignalRegistry,
+  readToolDeclarations,
+  settingsFactsDeclaration
+} from './capabilities'
+import { readOnlyPolicyDecision, resolveActionPolicy } from './policy'
+import type { ActionDeclaration, CapabilityId, JsonObject, PolicyMode, RuntimeContext } from './schema'
+
+export type SteerableFixtureKind = 'facts' | 'read_tool' | 'action' | 'undo'
+
+export interface SteerableFixture {
+  id: string
+  kind: SteerableFixtureKind
+  coverageCell: string
+  route: '/settings'
+  capabilityId: CapabilityId
+  params: JsonObject
+  expectedMode?: PolicyMode
+  expectUndo?: boolean
+}
+
+export interface ProbeResult {
+  ok: boolean
+  summary: string
+  checked: number
+  failures: string[]
+  coverageCells: string[]
+}
+
+export const quietSignalSteerableFixtures: readonly SteerableFixture[] = [
+  {
+    id: 'QS-STEER-FACTS-001',
+    kind: 'facts',
+    coverageCell: 'settings/facts/counts-status-no-raw-content',
+    route: '/settings',
+    capabilityId: 'settings.current_facts',
+    params: {}
+  },
+  {
+    id: 'QS-STEER-READ-001',
+    kind: 'read_tool',
+    coverageCell: 'settings/read/local-status-no-raw-content',
+    route: '/settings',
+    capabilityId: 'settings.get_local_status',
+    params: {},
+    expectedMode: 'Read-only'
+  },
+  {
+    id: 'QS-STEER-READ-002',
+    kind: 'read_tool',
+    coverageCell: 'settings/read/backup-status-no-file',
+    route: '/settings',
+    capabilityId: 'backup.get_status',
+    params: {},
+    expectedMode: 'Read-only'
+  },
+  {
+    id: 'QS-STEER-ACTION-001',
+    kind: 'action',
+    coverageCell: 'settings/action/theme-safe-undoable-ungated',
+    route: '/settings',
+    capabilityId: 'settings.set_theme',
+    params: { theme: 'dark' },
+    expectedMode: 'Optimistic chain',
+    expectUndo: true
+  },
+  {
+    id: 'QS-STEER-ACTION-002',
+    kind: 'action',
+    coverageCell: 'settings/action/daily-review-safe-undoable-ungated',
+    route: '/settings',
+    capabilityId: 'settings.set_daily_review',
+    params: { dailyCount: 5, dailyMode: 'balanced' },
+    expectedMode: 'Optimistic chain',
+    expectUndo: true
+  },
+  {
+    id: 'QS-STEER-GATED-001',
+    kind: 'action',
+    coverageCell: 'settings/action/backup-sensitive-external-step-gated',
+    route: '/settings',
+    capabilityId: 'backup.download_json',
+    params: {},
+    expectedMode: 'Step-gated',
+    expectUndo: false
+  },
+  {
+    id: 'QS-STEER-UNDO-001',
+    kind: 'undo',
+    coverageCell: 'settings/undo/theme-restores-previous-preference',
+    route: '/settings',
+    capabilityId: 'settings.set_theme',
+    params: { theme: 'light' },
+    expectedMode: 'Optimistic chain',
+    expectUndo: true
+  },
+  {
+    id: 'QS-STEER-UNDO-002',
+    kind: 'undo',
+    coverageCell: 'settings/undo/backup-honest-irrevocable-refusal',
+    route: '/settings',
+    capabilityId: 'backup.download_json',
+    params: {},
+    expectedMode: 'Step-gated',
+    expectUndo: false
+  }
+]
+
+export const quietSignalSteerableAdapter = {
+  target: quietSignalSteerableTarget.integrationId,
+  integrationId: quietSignalSteerableTarget.integrationId,
+  registry: {
+    id: quietSignalSteerableTarget.registryId,
+    version: quietSignalSteerableTarget.registryVersion,
+    ref: quietSignalSteerableTarget.registryRef
+  },
+  route(fixture: SteerableFixture) {
+    return fixture.route
+  },
+  resolve(fixture: SteerableFixture) {
+    if (fixture.kind === 'facts') {
+      return { declaration: settingsFactsDeclaration, policy: readOnlyPolicyDecision() }
+    }
+
+    const readTool = readToolDeclarations.find((tool) => tool.id === fixture.capabilityId)
+    if (readTool) return { declaration: readTool, policy: readOnlyPolicyDecision() }
+
+    const action = actionDeclarations.find((candidate) => candidate.id === fixture.capabilityId)
+    return action ? { declaration: action, policy: resolveActionPolicy(action) } : null
+  },
+  execute(fixture: SteerableFixture, context: RuntimeContext) {
+    const resolved = this.resolve(fixture)
+    if (!resolved) return { ok: false, message: `Unknown fixture capability: ${fixture.capabilityId}` }
+    const parsed = resolved.declaration.kind === 'facts' ? { ok: true as const, value: {} } : resolved.declaration.params.parse(fixture.params)
+    if (!parsed.ok) return { ok: false, message: parsed.error }
+
+    if (resolved.declaration.kind === 'facts') {
+      return { ok: true, result: resolved.declaration.publish(context) }
+    }
+    if (resolved.declaration.kind === 'read_tool') {
+      return { ok: true, result: resolved.declaration.read(context, parsed.value) }
+    }
+    if (resolved.policy.requiresApproval) {
+      return { ok: true, result: { held: true, mode: resolved.policy.mode } }
+    }
+    return { ok: true, result: resolved.declaration.execute(context, parsed.value) }
+  },
+  undo(fixture: SteerableFixture, context: RuntimeContext, undoPayload: JsonObject) {
+    const action = actionDeclarations.find((candidate) => candidate.id === fixture.capabilityId)
+    if (!action?.undo) return { ok: false, message: `No undo is available for ${fixture.capabilityId}` }
+    return { ok: true, result: action.undo(context, undoPayload) }
+  }
+}
+
+export function runSteerableFixtureProbe(): ProbeResult {
+  const failures: string[] = []
+  const fixtureIds = new Set<string>()
+  const coverageCells = new Set<string>()
+  const registryIds = [
+    ...quietSignalRegistry.surfaces.map((surface) => surface.id),
+    ...quietSignalRegistry.facts.map((facts) => facts.id),
+    ...quietSignalRegistry.readTools.map((tool) => tool.id),
+    ...quietSignalRegistry.actions.map((action) => action.id)
+  ]
+
+  findDuplicates(registryIds).forEach((id) => failures.push(`Duplicate registry id: ${id}`))
+
+  for (const fixture of quietSignalSteerableFixtures) {
+    if (fixtureIds.has(fixture.id)) failures.push(`Duplicate fixture id: ${fixture.id}`)
+    fixtureIds.add(fixture.id)
+    coverageCells.add(fixture.coverageCell)
+
+    if (fixture.route !== '/settings') failures.push(`${fixture.id} must stay scoped to /settings`)
+
+    const resolved = quietSignalSteerableAdapter.resolve(fixture)
+    if (!resolved) {
+      failures.push(`${fixture.id} references unknown capability ${fixture.capabilityId}`)
+      continue
+    }
+
+    if (resolved.declaration.kind !== 'facts') {
+      const parsed = resolved.declaration.params.parse(fixture.params)
+      if (!parsed.ok) failures.push(`${fixture.id} has invalid params: ${parsed.error}`)
+    }
+
+    if (resolved.declaration.kind === 'facts' && resolved.declaration.rawContentIncluded !== false) {
+      failures.push(`${fixture.id} facts must not include raw content`)
+    }
+
+    if (resolved.declaration.kind === 'read_tool' && resolved.declaration.rawContentIncluded !== false) {
+      failures.push(`${fixture.id} read tool must not include raw content`)
+    }
+
+    if (fixture.expectedMode && resolved.policy.mode !== fixture.expectedMode) {
+      failures.push(`${fixture.id} expected ${fixture.expectedMode}, got ${resolved.policy.mode}`)
+    }
+
+    if (resolved.declaration.kind === 'action') {
+      checkUndoExpectation(fixture, resolved.declaration, failures)
+    }
+  }
+
+  return {
+    ok: failures.length === 0,
+    summary: failures.length === 0 ? 'Steerable fixture probe passed.' : 'Steerable fixture probe failed.',
+    checked: quietSignalSteerableFixtures.length,
+    failures,
+    coverageCells: [...coverageCells]
+  }
+}
+
+function checkUndoExpectation(fixture: SteerableFixture, action: ActionDeclaration, failures: string[]) {
+  if (fixture.expectUndo === true && !action.undo) failures.push(`${fixture.id} expected undo but ${action.id} has none`)
+  if (fixture.expectUndo === false && action.undo) failures.push(`${fixture.id} expected honest no-undo but ${action.id} has undo`)
+}
+
+function findDuplicates(ids: readonly string[]) {
+  const seen = new Set<string>()
+  const duplicates = new Set<string>()
+  for (const id of ids) {
+    if (seen.has(id)) duplicates.add(id)
+    seen.add(id)
+  }
+  return [...duplicates]
+}
