+    id: 'settings.set_theme',
+    surface: 'settings',
+    title: 'Set theme',
+    description: 'Change the light or dark appearance preference.',
+    params: themeParams,
+    reads: ['settings.theme'],
+    writes: ['settings.theme', 'localStorage.quiet-signal-review-settings', 'document.theme_class'],
+    risk: 'safe',
+    reversibility: 'undoable',
+    effects: { external: false, cost: 'none', sensitive: false },
+    confirmation: 'never',
