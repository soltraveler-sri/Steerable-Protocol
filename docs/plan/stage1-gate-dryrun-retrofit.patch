diff --git a/scripts/steerable-probe.mjs b/scripts/steerable-probe.mjs
new file mode 100644
index 0000000..1a5c5cb
--- /dev/null
+++ b/scripts/steerable-probe.mjs
@@ -0,0 +1,109 @@
+import { readFileSync } from 'node:fs'
+import { join } from 'node:path'
+
+const root = process.cwd()
+const capabilities = read('src/steerable/capabilities.ts')
+const policy = read('src/steerable/policy.ts')
+const fixtures = read('src/steerable/fixtures.ts')
+const runtime = read('src/steerable/runtime.tsx')
+
+const failures = []
+
+for (const id of [
+  'settings.current_facts',
+  'settings.get_local_status',
+  'backup.get_status',
+  'library.get_export_summary',
+  'settings.set_theme',
+  'settings.set_daily_review',
+  'backup.download_json'
+]) {
+  includes(capabilities, id, `missing declaration ${id}`)
+}
+
+for (const fixtureId of [
+  'QS-STEER-FACTS-001',
+  'QS-STEER-READ-001',
+  'QS-STEER-READ-002',
+  'QS-STEER-ACTION-001',
+  'QS-STEER-ACTION-002',
+  'QS-STEER-GATED-001',
+  'QS-STEER-UNDO-001',
+  'QS-STEER-UNDO-002'
+]) {
+  includes(fixtures, fixtureId, `missing fixture ${fixtureId}`)
+}
+
+for (const cell of [
+  'settings/facts/counts-status-no-raw-content',
+  'settings/read/local-status-no-raw-content',
+  'settings/action/theme-safe-undoable-ungated',
+  'settings/action/backup-sensitive-external-step-gated',
+  'settings/undo/theme-restores-previous-preference',
+  'settings/undo/backup-honest-irrevocable-refusal'
+]) {
+  includes(fixtures, cell, `missing coverage cell ${cell}`)
+}
+
+includes(capabilities, "rawContentIncluded: false", 'facts/read tools must explicitly exclude raw content')
+includes(capabilities, "facts: ['route', 'library', 'backup', 'security', 'preferences', 'storage', 'policy']", 'facts declaration must list finite top-level keys')
+includes(capabilities, "externalExposure: 'none'", 'capability declarations must materialize externalExposure defaults')
+includes(capabilities, "risk: 'safe'", 'safe action risk declarations missing')
+includes(capabilities, "risk: 'side_effect'", 'backup side-effect risk declaration missing')
+includes(capabilities, "reversibility: 'irreversible'", 'backup irreversible declaration missing')
+includes(capabilities, 'effects: { external: true, cost: \'none\', sensitive: true }', 'backup sensitive external effect declaration missing')
+includes(policy, "'settings.set_theme': 'Optimistic chain'", 'theme policy contrast missing')
+includes(policy, "'settings.set_daily_review': 'Optimistic chain'", 'daily review policy contrast missing')
+includes(policy, "'backup.download_json': 'Step-gated'", 'backup policy contrast missing')
+includes(policy, 'safe_reversible_preference', 'safe reversible policy reason code missing')
+includes(policy, 'sensitive_external_irreversible', 'sensitive backup policy reason code missing')
+includes(runtime, "kind: 'policy'", 'runtime must append a separate policy record')
+includes(runtime, "kind: 'approval'", 'runtime must append a separate approval record')
+includes(runtime, "decision.requiresApproval ? 'pending_approval' : 'running'", 'runtime must hold gated actions before execution')
+includes(runtime, 'action.captureUndo?.', 'runtime must capture undo before execution')
+includes(runtime, 'action.undo(runtimeContext', 'runtime must execute declared undo handlers')
+
+const fixtureIds = matches(fixtures, /id: '(QS-STEER-[^']+)'/g)
+const duplicateFixtureIds = duplicates(fixtureIds)
+if (duplicateFixtureIds.length) failures.push(`duplicate fixture ids: ${duplicateFixtureIds.join(', ')}`)
+
+if (failures.length) {
+  console.error('Steerable probe failed:')
+  for (const failure of failures) console.error(`- ${failure}`)
+  process.exit(1)
+}
+
+console.log(
+  JSON.stringify(
+    {
+      ok: true,
+      checkedFiles: ['src/steerable/capabilities.ts', 'src/steerable/policy.ts', 'src/steerable/fixtures.ts', 'src/steerable/runtime.tsx'],
+      fixtures: fixtureIds.length,
+      message: 'Steerable static fixture probe passed.'
+    },
+    null,
+    2
+  )
+)
+
+function read(path) {
+  return readFileSync(join(root, path), 'utf8')
+}
+
+function includes(source, needle, message) {
+  if (!source.includes(needle)) failures.push(message)
+}
+
+function matches(source, regex) {
+  return [...source.matchAll(regex)].map((match) => match[1])
+}
+
+function duplicates(values) {
+  const seen = new Set()
+  const dupes = new Set()
+  for (const value of values) {
+    if (seen.has(value)) dupes.add(value)
+    seen.add(value)
+  }
+  return [...dupes]
+}
