{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "intent-routing.schema.json",
  "title": "Steerable intent-routing eval fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fixtureFormatVersion",
    "kind",
    "id",
    "title",
    "description",
    "authoredBy",
    "authoredDate",
    "target",
    "sample",
    "requirementRefs",
    "given",
    "expected"
  ],
  "properties": {
    "fixtureFormatVersion": { "const": "0.1.0" },
    "kind": { "const": "intent-routing" },
    "id": { "$ref": "common.schema.json#/definitions/fixtureId" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "authoredBy": { "type": "string", "minLength": 1 },
    "authoredDate": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "target": { "$ref": "common.schema.json#/definitions/target" },
    "sample": { "$ref": "common.schema.json#/definitions/sampleMarker" },
    "requirementRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "common.schema.json#/definitions/requirementRef" }
    },
    "given": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surfaceId", "utterance"],
      "properties": {
        "surfaceId": { "$ref": "common.schema.json#/definitions/surfaceId" },
        "utterance": { "type": "string", "minLength": 1 },
        "facts": { "$ref": "common.schema.json#/definitions/jsonObject" },
        "posturePreset": { "$ref": "common.schema.json#/definitions/posturePreset" },
        "sessionContext": { "$ref": "common.schema.json#/definitions/jsonObject" }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["routeClass", "negativeCase"],
      "properties": {
        "routeClass": { "$ref": "common.schema.json#/definitions/routeClass" },
        "negativeCase": { "$ref": "common.schema.json#/definitions/negativeCase" },
        "actions": {
          "type": "array",
          "items": { "$ref": "common.schema.json#/definitions/expectedAction" }
        },
        "readTools": {
          "type": "array",
          "items": { "$ref": "common.schema.json#/definitions/capabilityId" }
        },
        "answer": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "mustUseFacts": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "messageContains": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "clarification": {
          "type": "object",
          "additionalProperties": false,
          "required": ["missing"],
          "properties": {
            "missing": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["field", "reason"],
                "properties": {
                  "field": { "type": "string", "minLength": 1 },
                  "reason": { "type": "string", "minLength": 1 }
                }
              }
            }
          }
        },
        "refusal": { "$ref": "common.schema.json#/definitions/disclosure" },
        "escalationReason": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": {
            "properties": { "routeClass": { "const": "clarification" } },
            "required": ["routeClass"]
          },
          "then": { "required": ["clarification"] }
        },
        {
          "if": {
            "properties": { "routeClass": { "const": "refusal/handoff" } },
            "required": ["routeClass"]
          },
          "then": { "required": ["refusal"] }
        }
      ]
    }
  }
}
