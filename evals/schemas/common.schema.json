{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "common.schema.json",
  "title": "Steerable eval fixture common definitions",
  "definitions": {
    "jsonValue": {
      "description": "Any JSON-serializable value.",
      "oneOf": [
        { "type": "null" },
        { "type": "boolean" },
        { "type": "number" },
        { "type": "string" },
        {
          "type": "array",
          "items": { "$ref": "#/definitions/jsonValue" }
        },
        {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/jsonValue" }
        }
      ]
    },
    "jsonObject": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/jsonValue" }
    },
    "fixtureId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "capabilityId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$"
    },
    "surfaceId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*(\\.[a-z][a-z0-9_-]*)*$"
    },
    "requirementRef": {
      "type": "string",
      "pattern": "^SA-[A-Z]+-[0-9]{3}$"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["integrationId", "registry"],
      "properties": {
        "integrationId": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._-]*$"
        },
        "registry": {
          "type": "object",
          "additionalProperties": false,
          "required": ["id", "version", "ref"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "version": { "type": "string", "minLength": 1 },
            "ref": { "type": "string", "minLength": 1 },
            "digest": {
              "description": "Optional content digest for immutable registry artifacts.",
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "sampleMarker": {
      "type": "object",
      "additionalProperties": false,
      "required": ["isSample", "note"],
      "properties": {
        "isSample": { "type": "boolean" },
        "note": { "type": "string", "minLength": 1 }
      }
    },
    "matcher": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "value"],
          "properties": {
            "kind": { "const": "exact" },
            "value": { "$ref": "#/definitions/jsonValue" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "values"],
          "properties": {
            "kind": { "const": "oneOf" },
            "values": {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/definitions/jsonValue" }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "value"],
          "properties": {
            "kind": { "const": "caseInsensitive" },
            "value": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "value", "tolerance"],
          "properties": {
            "kind": { "const": "numericTolerance" },
            "value": { "type": "number" },
            "tolerance": { "type": "number", "minimum": 0 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "values"],
          "properties": {
            "kind": { "const": "arrayUnordered" },
            "values": {
              "type": "array",
              "items": { "$ref": "#/definitions/jsonValue" }
            }
          }
        }
      ]
    },
    "paramExpectation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["allowExtra", "fields"],
      "properties": {
        "allowExtra": { "type": "boolean" },
        "fields": {
          "type": "object",
          "additionalProperties": { "$ref": "#/definitions/matcher" }
        }
      }
    },
    "expectedAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actionId"],
      "properties": {
        "stepId": { "$ref": "#/definitions/fixtureId" },
        "actionId": { "$ref": "#/definitions/capabilityId" },
        "surfaceId": { "$ref": "#/definitions/surfaceId" },
        "params": { "$ref": "#/definitions/paramExpectation" }
      }
    },
    "routeClass": {
      "enum": [
        "answer",
        "single action",
        "action chain",
        "workflow needing the loop",
        "clarification",
        "refusal/handoff"
      ]
    },
    "autonomyMode": {
      "enum": [
        "Read-only",
        "Instant execution",
        "Optimistic chain",
        "Gated suffix",
        "Plan preview",
        "Step-gated",
        "Refuse / hand off"
      ]
    },
    "posturePreset": {
      "enum": ["creative-tool", "business-app", "sensitive-domain"]
    },
    "negativeCase": {
      "enum": [
        "none",
        "clarification",
        "refusal",
        "policy-denial",
        "undo-refusal",
        "timeout-failure",
        "capability-unavailable",
        "partial-undo"
      ]
    },
    "disclosure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reasonCode", "messageContains"],
      "properties": {
        "reasonCode": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "messageContains": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "requirementRefs": {
          "type": "array",
          "items": { "$ref": "#/definitions/requirementRef" }
        }
      }
    },
    "baseRootProperties": {
      "type": "object",
      "properties": {
        "fixtureFormatVersion": { "const": "0.1.0" },
        "id": { "$ref": "#/definitions/fixtureId" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "authoredBy": { "type": "string", "minLength": 1 },
        "authoredDate": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
        },
        "target": { "$ref": "#/definitions/target" },
        "sample": { "$ref": "#/definitions/sampleMarker" },
        "requirementRefs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/requirementRef" }
        }
      }
    }
  }
}
