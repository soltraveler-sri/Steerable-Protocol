{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "policy-decisions.schema.json",
  "title": "Steerable policy-decisions eval fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fixtureFormatVersion",
    "kind",
    "id",
    "title",
    "description",
    "authoredBy",
    "authoredDate",
    "target",
    "sample",
    "requirementRefs",
    "given",
    "expected"
  ],
  "properties": {
    "fixtureFormatVersion": { "const": "0.1.0" },
    "kind": { "const": "policy-decisions" },
    "id": { "$ref": "common.schema.json#/definitions/fixtureId" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "authoredBy": { "type": "string", "minLength": 1 },
    "authoredDate": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "target": { "$ref": "common.schema.json#/definitions/target" },
    "sample": { "$ref": "common.schema.json#/definitions/sampleMarker" },
    "requirementRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "common.schema.json#/definitions/requirementRef" }
    },
    "given": {
      "type": "object",
      "additionalProperties": false,
      "required": ["posturePreset", "surfaceId", "proposed"],
      "properties": {
        "posturePreset": { "$ref": "common.schema.json#/definitions/posturePreset" },
        "surfaceId": { "$ref": "common.schema.json#/definitions/surfaceId" },
        "sessionContext": { "$ref": "common.schema.json#/definitions/jsonObject" },
        "runtimeSignals": { "$ref": "common.schema.json#/definitions/jsonObject" },
        "stickyGrants": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["grantId", "subject", "effect", "expires"],
            "properties": {
              "grantId": { "$ref": "common.schema.json#/definitions/fixtureId" },
              "subject": { "type": "string", "minLength": 1 },
              "effect": { "$ref": "common.schema.json#/definitions/autonomyMode" },
              "expires": { "type": "string", "minLength": 1 },
              "source": { "enum": ["framework", "developer"] },
              "sessionId": { "type": "string", "minLength": 1 }
            }
          }
        },
        "proposed": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "steps"],
          "properties": {
            "kind": { "enum": ["action", "chain"] },
            "steps": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["stepId", "actionId"],
                "properties": {
                  "stepId": { "$ref": "common.schema.json#/definitions/fixtureId" },
                  "actionId": { "$ref": "common.schema.json#/definitions/capabilityId" },
                  "surfaceId": { "$ref": "common.schema.json#/definitions/surfaceId" },
                  "params": { "$ref": "common.schema.json#/definitions/jsonObject" }
                }
              }
            }
          }
        }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["negativeCase", "steps"],
      "properties": {
        "negativeCase": { "$ref": "common.schema.json#/definitions/negativeCase" },
        "chainMode": { "$ref": "common.schema.json#/definitions/autonomyMode" },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["stepId", "actionId", "resolvedMode"],
            "properties": {
              "stepId": { "$ref": "common.schema.json#/definitions/fixtureId" },
              "actionId": { "$ref": "common.schema.json#/definitions/capabilityId" },
              "resolvedMode": { "$ref": "common.schema.json#/definitions/autonomyMode" },
              "reasonCodes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_]*$"
                }
              }
            }
          }
        },
        "boundaries": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "executedPrefixThroughStepId": { "$ref": "common.schema.json#/definitions/fixtureId" },
            "heldSuffixFromStepId": { "$ref": "common.schema.json#/definitions/fixtureId" },
            "requiredGate": { "type": "string", "minLength": 1 }
          }
        },
        "denial": { "$ref": "common.schema.json#/definitions/disclosure" },
        "rationaleMustInclude": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "negativeCase": { "const": "policy-denial" }
            },
            "required": ["negativeCase"]
          },
          "then": { "required": ["denial"] }
        }
      ]
    }
  }
}
