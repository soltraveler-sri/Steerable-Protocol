{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "facts-context.schema.json",
  "title": "Steerable facts-context eval fixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "fixtureFormatVersion",
    "kind",
    "id",
    "title",
    "description",
    "authoredBy",
    "authoredDate",
    "target",
    "sample",
    "requirementRefs",
    "given",
    "expected"
  ],
  "properties": {
    "fixtureFormatVersion": { "const": "0.1.0" },
    "kind": { "const": "facts-context" },
    "id": { "$ref": "common.schema.json#/definitions/fixtureId" },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "authoredBy": { "type": "string", "minLength": 1 },
    "authoredDate": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
    },
    "target": { "$ref": "common.schema.json#/definitions/target" },
    "sample": { "$ref": "common.schema.json#/definitions/sampleMarker" },
    "requirementRefs": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "common.schema.json#/definitions/requirementRef" }
    },
    "given": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surfaceId"],
      "properties": {
        "surfaceId": { "$ref": "common.schema.json#/definitions/surfaceId" },
        "readToolCalls": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "params"],
            "properties": {
              "id": { "$ref": "common.schema.json#/definitions/capabilityId" },
              "params": { "$ref": "common.schema.json#/definitions/jsonObject" }
            }
          }
        }
      }
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "required": ["facts"],
      "properties": {
        "facts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "values"],
            "properties": {
              "id": { "$ref": "common.schema.json#/definitions/capabilityId" },
              "values": { "$ref": "common.schema.json#/definitions/paramExpectation" }
            }
          }
        },
        "readTools": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "result"],
            "properties": {
              "id": { "$ref": "common.schema.json#/definitions/capabilityId" },
              "result": { "$ref": "common.schema.json#/definitions/paramExpectation" }
            }
          }
        }
      }
    }
  }
}
